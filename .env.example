# =============================================================
# Nour Academy - Environment Variables for Railway Deployment
# =============================================================
# Copy this file, fill in your values, and add them to Railway's
# service environment variables dashboard.
# =============================================================

# --- Database (Railway PostgreSQL) ---
# Copy the DATABASE_URL from your Railway PostgreSQL service
DATABASE_URL=postgresql://user:password@host:port/dbname

# --- Server ---
# Railway sets PORT automatically — do NOT override it
# PORT=3000

# --- Admin Panel ---
# Password to access the /admin page
ADMIN_PASSWORD=your_secure_admin_password_here

# --- Google Sheets Integration (optional) ---
# Used to forward student registrations to Google Sheets
# Leave empty if not using this feature
GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# --- Node Environment ---
NODE_ENV=production
